# eBay API (required). Get keys: https://developer.ebay.com/my/keys
# EBAY_APP_ID=    (Client ID)
# EBAY_CERT_ID=  (Client Secret)
# EBAY_SANDBOX=true   use sandbox; set to false for production

# Optional: API key for protecting HTTP and MCP endpoints (when set, use Authorization: Bearer <key> or X-API-Key: <key>)
# If using Open WebUI or other MCP clients that cannot send headers, leave unset or configure the client to send the key.
# EBAY_API_KEY=

# Server
# PORT=3000
# MCP_PORT=3100
# MCP_HOST=0.0.0.0

# MCP allowed Host header values (comma-separated). Default includes localhost and 'ebay-automation'.
# Open WebUI calls MCP from the browser, so use a URL the browser can reach (e.g. http://localhost:3000/mcp
# or http://YOUR_SERVER_IP:3000/mcp) and ensure that host is allowed below.
# Examples: add 192.168.10.20 if you use http://192.168.10.20:3000/mcp from Open WebUI.
# MCP_ALLOWED_HOSTS=localhost,127.0.0.1,ebay-automation,192.168.10.20
